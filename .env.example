# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Authentication settings
USE_AUTH=false

# FHIR Server Configuration
FHIR_SERVER=https://your-fhir-server.com/fhir/DEFAULT
FHIR_USERNAME=your_username
FHIR_PASSWORD=your_password

# Example for development:
# FHIR_SERVER=https://smile.sparked-fhir.com/ereq/fhir/DEFAULT
# FHIR_USERNAME=placer
# FHIR_PASSWORD=your_actual_password_here

# Australian Provider Directory — FHIR R4, no auth required
# Default: https://fhir-xrp.digitalhealth.gov.au/fhir (override to use a different instance)
# X-Request-ID UUID header is added automatically per request.
PD_SERVER=

# AU Patient Summary Producer endpoint (Scenario 1, proposal 03)
# Defaults to FHIR_SERVER if the same server exposes $summary
PS_PRODUCER=


# Code Search 
CODESEARCH_API_ENDPOINT=
CODESEARCH_TOKEN_ENDPOINT=
CODESEARCH_CLIENT_ID=
CODESEARCH_CLIENT_SECRET=
CODESEARCH_CONTENT_TYPE=


# Locator service API Keys (geospace.com.au)
GNAF_CONSUMER_KEY=
GNAF_CONSUMER_SECRET=
